# Python cache and build artifacts
__pycache__/
*.py[cod]
*.so
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# IDE/editor
.DS_Store
.vscode/
.idea/

# Local spectrum cache (regenerated by the code; can be hundreds of MB)
data/.spectrum_cache/

# Results and local data artifacts
results/*
!results/.gitkeep
data/processed/*
!data/processed/.gitkeep
